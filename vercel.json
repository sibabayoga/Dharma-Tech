{
    "version": 2,
    "framework": null,
    "installCommand": "cd dharma-tech-os && composer install --no-dev --optimize-autoloader",
    "buildCommand": "cd dharma-tech-os && npm install && npm run build",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/dharma-tech-os/public/build/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/dharma-tech-os/public/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/dharma-tech-os/public/js/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
